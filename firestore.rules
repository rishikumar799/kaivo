rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global settings, contact info, menu builder, announcements, about content, seo, and popup
    match /settings/global {
      allow read: if true;
      allow write: if true;
    }
    match /offers/global {
      allow read: if true;
      allow write: if true;
    }
    match /about/global {
      allow read: if true;
      allow write: if true;
    }
    match /contact/global {
      allow read: if true;
      allow write: if true;
    }
    match /menus/global {
      allow read: if true;
      allow write: if true;
    }
    match /seo/global {
      allow read: if true;
      allow write: if true;
    }
    match /popup/global {
      allow read: if true;
      allow write: if true;
    }

    // Collections
    match /banners/{bannerId} {
      allow read: if true;
      allow write: if true;
    }
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if true;
    }
    match /products/{productId} {
      allow read: if true;
      allow write: if true;
    }
    match /testimonials/{testimonialId} {
      allow read: if true;
      allow write: if true;
    }
    match /pages/{pageId} {
      allow read: if true;
      allow write: if true;
    }
    match /media/{mediaId} {
      allow read: if true;
      allow write: if true;
    }

    match /product_views/{id} {
      allow read: if true;
      allow write: if true;
    }

    match /whatsapp_clicks/{id} {
      allow read: if true;
      allow write: if true;
    }

    match /analytics/{id} {
      allow read: if true;
      allow write: if true;
    }
    
    // Global default fallback
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
